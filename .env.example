# =============================================================================
# DryDocs — environment variables template
# Copy this file to `.env` and fill in values. `.env` is gitignored.
# =============================================================================

# --- Neo4j connection (required) ---------------------------------------------
# NEO4J_USER maps to the `user` field in Neo4jSettings (prefix NEO4J_).
# Aura: use the short instance ID shown in the Connect panel (e.g. "neo4j").
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# --- Oracle (optional — M1+) -------------------------------------------------
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_DSN=

# --- GitHub (optional — code loader) -----------------------------------------
GITHUB_TOKEN=
GITHUB_USER=

# --- LLM keys (optional — GraphRAG experiments) ------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Neo4j Aura API (optional — instance management) -------------------------
AURA_CLIENT_ID=
AURA_CLIENT_SECRET=
AURA_INSTANCEID=
AURA_INSTANCENAME=
